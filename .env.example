# Optional Supabase client configuration for account-level user-state sync
# and the read-only Today real-content preview.
# Leave these blank to keep the app in local-only / mock-default mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Keep false by default so Today remains on the mock feed unless
# real-content preview is intentionally enabled locally.
VITE_USE_REAL_CONTENT_FEED=false
